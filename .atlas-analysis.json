  "keyFeatures": [
    "Employee Lifecycle Management (onboarding, transfers, promotions, separation)",
    "Leave and Attendance tracking with geolocation check-in/check-out",
    "Payroll processing with salary structures, tax slabs, and compliance",
    "Performance Management with goals, KRAs, appraisal cycles, and feedback",
    "Expense Claims and Employee Advances with multi-level approval workflows",
    "Recruitment module with job openings, applicant tracking, and interviews",
    "Shift Management with auto-attendance processing",
    "Mobile PWA app for leaves, attendance, and expense claims",
    "Regional payroll compliance (India, UAE)",
    "ERPNext integration for accounting and financial operations"
  ],
